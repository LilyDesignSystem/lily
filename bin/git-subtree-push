#!/bin/sh

# git-subtree-push: Use git to publish the monorepo's subprojects.
#
# Syntax:
# 
# ```sh
# git-subtree-push
# git-subtree-push --force
# git-subtree-push --remote-add
# ```
# 
# ## Add remotes for each subproject
# 
# ```sh
# ```
#
# Notes:
# 
# - The target repos must exist on GitHub first (create them empty, no README/license/gitignore)
# - `git subtree push` rewrites history so only commits touching that prefix are included
# - For large repos, the first push can be slow since it replays the entire history
# - To re-run later after new commits, just repeat the `git subtree push` commands
# 
# The 
# 
# ## Force push
#
# The winning pattern for force-pushing subtrees is:
#
# ```sh
# git subtree split --prefix=<folder> --branch temp-split
# git push <remote> temp-split:main --force
# git branch -D temp-split
# ```
# 
# The `--branch flag is the key — it creates a real local branch from the split,
# bypassing any stale cache that could cause the error "no new revisions found".
#

set -euf
top="$(git rev-parse --show-toplevel)"

if [ $# -eq 0 ]; then
    for implementation in $("$top/bin/list-implementations"); do
        git subtree push --prefix=$implementation $implementation main
    done
    exit 0
fi

if [ $# -eq 1 ] && [ $1 = "--force" ]; then
    for implementation in $("$top/bin/list-implementations"); do
        git subtree split --prefix=$implementation --branch temp-split && git push $implementation temp-split:main --force && git branch -D temp-split
    done
    exit 0
fi

if [ $# -eq 1 ] && [ $1 = "--remote-add" ]; then
    for implementation in $("$top/bin/list-implementations"); do
        git remote add $implementation git@github.com:LilyDesignSystem/$implementation.git
    done
    exit 0
fi
